{
  "name": "ai-workspace-configurator",
  "version": "3.6.0",
  "description": "AI Workspace Configurator — From clean Windows 11 to WSL2 vibe-coding in 15 steps",
  "main": "electron/main.js",
  "author": "AI Workspace Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "cd .. && npm run build",
    "build:electron": "electron-builder --win --publish=never",
    "build:portable": "electron-builder --win portable --publish=never",
    "dist": "npm run build:react && electron-builder --win --publish=never",
    "dist:all": "npm run build:react && electron-builder --win --mac --linux --publish=never",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.aiworkspace.configurator",
    "productName": "AI Workspace Configurator",
    "directories": {
      "output": "../dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "../dist/**/*",
      "scripts/**/*",
      "configs/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": "*.ps1"
      },
      {
        "from": "configs",
        "to": "configs",
        "filter": "*"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "AI Workspace Team"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Workspace Configurator",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "AI-Workspace-Configurator-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "AI-Workspace-Configurator-Portable-${version}.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "FlexNetOS",
      "repo": "ai-workspace-configurator"
    }
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^25.0.0"
  }
}
